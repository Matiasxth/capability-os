{
  "_doc": "Security classification rules. Level 1=free, 2=confirm, 3=password. Tools not listed default to Level 2.",

  "free": {
    "_doc": "Level 1: No confirmation needed — read-only and safe operations",
    "tools": [
      "filesystem_read_file",
      "filesystem_list_directory",
      "system_get_os_info",
      "system_get_env_var",
      "system_get_workspace_info",
      "network_http_get",
      "network_extract_text",
      "network_extract_links",
      "network_parse_html",
      "browser_read_text",
      "browser_screenshot",
      "browser_take_screenshot",
      "browser_list_interactive_elements",
      "browser_list_tabs",
      "browser_highlight_element"
    ],
    "capabilities": [
      "read_file",
      "list_directory",
      "analyze_project",
      "get_system_status",
      "get_capability_status",
      "get_error_report",
      "get_integration_status",
      "list_integrations",
      "fetch_url",
      "read_web_page",
      "extract_text",
      "extract_links",
      "parse_html",
      "diagnose_error",
      "search_whatsapp_chat",
      "read_whatsapp_messages",
      "list_whatsapp_visible_chats",
      "send_whatsapp_message",
      "send_telegram_message",
      "send_telegram_photo",
      "get_telegram_updates",
      "send_slack_message",
      "send_discord_message",
      "load_sequence",
      "list_processes"
    ]
  },

  "confirm": {
    "_doc": "Level 2: User must click Allow — write/modify operations within workspace",
    "tools": [
      "filesystem_write_file",
      "filesystem_create_directory",
      "filesystem_delete_file",
      "filesystem_delete_directory",
      "filesystem_copy_file",
      "filesystem_move_file",
      "execution_run_command",
      "execution_run_script",
      "browser_open_session",
      "browser_close_session",
      "browser_navigate",
      "browser_click_element",
      "browser_click_element_by_id",
      "browser_type_text",
      "browser_type_into_element",
      "browser_wait_for_selector",
      "browser_switch_tab",
      "network_http_post"
    ],
    "capabilities": [
      "write_file",
      "edit_file",
      "copy_file",
      "move_file",
      "delete_file",
      "create_directory",
      "delete_directory",
      "create_project",
      "modify_code",
      "execute_command",
      "execute_script",
      "run_tests",
      "run_build",
      "open_browser",
      "navigate_web",
      "interact_with_page",
      "save_sequence",
      "run_sequence"
    ]
  },

  "protected": {
    "_doc": "Level 3: Password/2FA required — system-level, destructive, or sensitive operations",
    "tools": [
      "execution_terminate_process",
      "execution_list_processes"
    ],
    "capabilities": [
      "stop_process",
      "install_integration",
      "uninstall_integration",
      "validate_integration"
    ]
  },

  "critical_paths": {
    "_doc": "Paths that ALWAYS require Level 3 regardless of tool",
    "patterns": [
      "C:\\Windows",
      "C:\\Program Files",
      "C:\\Program Files (x86)",
      "/etc",
      "/usr",
      "/bin",
      "/sbin",
      "/var",
      "/root",
      ".env",
      ".ssh",
      "credentials",
      "secrets",
      "tokens",
      "password"
    ]
  }
}
