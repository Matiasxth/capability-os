{
  "id": "extract_text",
  "name": "Extract text",
  "domain": "web",
  "type": "base",
  "description": "Extract plain text content from a parsed HTML document object.",
  "inputs": {
    "document": {"type": "object", "required": true, "description": "Parsed document from parse_html or network_parse_html."}
  },
  "outputs": {
    "text": {"type": "string"},
    "word_count": {"type": "integer"}
  },
  "requirements": {
    "tools": ["network_extract_text"],
    "capabilities": ["parse_html"],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "extract_text",
        "action": "network_extract_text",
        "params": {
          "document": "{{inputs.document}}"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": ["extract text", "extraer texto", "get text from html", "obtener texto"]
  },
  "lifecycle": {
    "version": "1.1.0",
    "status": "ready"
  }
}
