{
  "id": "load_sequence",
  "name": "Load sequence",
  "domain": "automatizacion",
  "type": "base",
  "description": "Load a reusable sequence definition from workspace storage.",
  "inputs": {
    "sequence_id": {"type": "string", "required": true, "description": "Saved sequence id."}
  },
  "outputs": {
    "sequence_definition": {"type": "object"}
  },
  "requirements": {
    "tools": ["filesystem_read_file"],
    "capabilities": [],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "load_sequence",
        "action": "filesystem_read_file",
        "params": {
          "path": "sequences/{{inputs.sequence_id}}.json"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": ["load sequence", "cargar secuencia"]
  },
  "lifecycle": {
    "version": "1.1.0",
    "status": "ready"
  }
}
