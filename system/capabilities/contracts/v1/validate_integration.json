{
  "id": "validate_integration",
  "name": "Validate integration",
  "domain": "integraciones",
  "type": "base",
  "description": "Validate that an installed integration manifest is well-formed and all required files are present.",
  "inputs": {
    "integration_id": {"type": "string", "required": true, "description": "Integration identifier to validate."}
  },
  "outputs": {
    "content": {"type": "string"},
    "path": {"type": "string"},
    "validation_result": {"type": "object"}
  },
  "requirements": {
    "tools": ["filesystem_read_file"],
    "capabilities": [],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "read_manifest",
        "action": "filesystem_read_file",
        "params": {
          "path": "system/integrations/installed/{{inputs.integration_id}}/manifest.json"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": ["validate integration", "validar integracion", "check integration"]
  },
  "lifecycle": {
    "version": "1.1.0",
    "status": "ready"
  }
}
