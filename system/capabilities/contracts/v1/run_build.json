{
  "id": "run_build",
  "name": "Run build",
  "domain": "desarrollo",
  "type": "composed",
  "description": "Run build command inside project directory.",
  "inputs": {
    "project_path": {"type": "string", "required": true, "description": "Project path inside workspace."},
    "build_command": {"type": "string", "required": false, "description": "Optional custom build command."}
  },
  "outputs": {
    "stdout": {"type": "string"},
    "exit_code": {"type": "integer"}
  },
  "requirements": {
    "tools": ["execution_run_command"],
    "capabilities": [],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "run_build",
        "action": "execution_run_command",
        "params": {
          "command": "{{inputs.build_command}}",
          "fallback_command": "py -c \"print('build_ok')\"",
          "cwd": "{{inputs.project_path}}"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": ["run build", "ejecutar build"]
  },
  "lifecycle": {
    "version": "1.1.0",
    "status": "ready"
  }
}
