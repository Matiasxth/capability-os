{
  "id": "browser_highlight_element",
  "name": "Highlight element",
  "domain": "web",
  "type": "base",
  "description": "Highlight an interactive element for debugging using its element_id.",
  "inputs": {
    "session_id": {"type": "string", "required": true, "description": "Browser session identifier."},
    "element_id": {"type": "string", "required": true, "description": "Interactive element identifier."},
    "duration_ms": {"type": "integer", "required": false, "description": "Highlight duration in milliseconds."},
    "timeout_ms": {"type": "integer", "required": false, "description": "Optional timeout override in milliseconds."}
  },
  "outputs": {
    "status": {"type": "string", "enum": ["success", "error"]},
    "session_id": {"type": "string"},
    "element_id": {"type": "string"},
    "selector": {"type": "string"},
    "url": {"type": "string"}
  },
  "requirements": {
    "tools": ["browser_highlight_element"],
    "capabilities": [],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "highlight_by_id",
        "action": "browser_highlight_element",
        "params": {
          "session_id": "{{inputs.session_id}}",
          "element_id": "{{inputs.element_id}}",
          "duration_ms": "{{inputs.duration_ms}}",
          "timeout_ms": "{{inputs.timeout_ms}}"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": ["highlight element", "resaltar elemento"]
  },
  "lifecycle": {
    "version": "1.0.0",
    "status": "ready"
  }
}
