{
  "id": "send_whatsapp_message",
  "name": "Send WhatsApp message",
  "domain": "integraciones",
  "type": "integration",
  "description": "Send a text message to the currently open WhatsApp chat.",
  "inputs": {
    "session_id": {
      "type": "string",
      "required": false,
      "description": "Optional browser session identifier."
    },
    "message": {
      "type": "string",
      "required": true,
      "description": "Text message to send."
    },
    "timeout_ms": {
      "type": "integer",
      "required": false,
      "description": "Timeout in milliseconds for browser actions."
    }
  },
  "outputs": {
    "status": {"type": "string", "enum": ["success", "error"]},
    "session_id": {"type": "string"},
    "message": {"type": "string"},
    "confirmation": {"type": "string"}
  },
  "requirements": {
    "tools": ["browser_click_element", "browser_type_text", "browser_wait_for_selector"],
    "capabilities": [],
    "integrations": ["whatsapp_web_connector"]
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "focus_message_input",
        "action": "browser_click_element",
        "params": {
          "session_id": "{{inputs.session_id}}",
          "selector": "div[contenteditable='true']",
          "timeout_ms": "{{inputs.timeout_ms}}"
        }
      },
      {
        "step_id": "type_message",
        "action": "browser_type_text",
        "params": {
          "session_id": "{{inputs.session_id}}",
          "selector": "div[contenteditable='true']",
          "text": "{{inputs.message}}",
          "timeout_ms": "{{inputs.timeout_ms}}"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": ["send whatsapp message", "enviar mensaje whatsapp"]
  },
  "lifecycle": {
    "version": "1.0.0",
    "status": "ready"
  }
}

