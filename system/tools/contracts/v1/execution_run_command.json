{
  "id": "execution_run_command",
  "name": "Run command",
  "category": "execution",
  "description": "Execute an allowlisted command inside the workspace.",
  "inputs": {
    "command": {"type": "string", "required": true, "description": "Command to execute."},
    "fallback_command": {"type": "string", "required": false, "description": "Optional fallback command used when command is empty."},
    "cwd": {"type": "string", "required": false, "description": "Optional working directory."}
  },
  "outputs": {
    "stdout": {"type": "string"},
    "stderr": {"type": "string"},
    "exit_code": {"type": "integer"}
  },
  "constraints": {
    "timeout_ms": 30000,
    "allowlist": ["npm", "node", "python", "pytest", "git", "npx", "py"],
    "workspace_only": true
  },
  "safety": {
    "level": "medium",
    "requires_confirmation": false
  },
  "lifecycle": {
    "version": "1.1.0",
    "status": "ready"
  }
}
