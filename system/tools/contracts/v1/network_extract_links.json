{
  "id": "network_extract_links",
  "name": "Extract links",
  "category": "network",
  "description": "Extract hyperlinks from a parsed HTML document object.",
  "inputs": {
    "document": {"type": "object", "required": true, "description": "Parsed document object from network_parse_html."}
  },
  "outputs": {
    "links": {"type": "array"},
    "count": {"type": "integer"}
  },
  "constraints": {
    "timeout_ms": 5000,
    "allowlist": [],
    "workspace_only": false
  },
  "safety": {
    "level": "low",
    "requires_confirmation": false
  },
  "lifecycle": {
    "version": "1.1.0",
    "status": "ready"
  }
}
