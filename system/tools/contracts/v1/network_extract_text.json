{
  "id": "network_extract_text",
  "name": "Extract text",
  "category": "network",
  "description": "Extract plain text content from a parsed HTML document object.",
  "inputs": {
    "document": {"type": "object", "required": true, "description": "Parsed document object from network_parse_html."}
  },
  "outputs": {
    "text": {"type": "string"},
    "word_count": {"type": "integer"}
  },
  "constraints": {
    "timeout_ms": 5000,
    "allowlist": [],
    "workspace_only": false
  },
  "safety": {
    "level": "low",
    "requires_confirmation": false
  },
  "lifecycle": {
    "version": "1.1.0",
    "status": "ready"
  }
}
