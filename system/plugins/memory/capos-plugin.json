{
  "id": "capos.core.memory",
  "name": "Memory",
  "version": "1.0.0",
  "dependencies": [
    "capos.core.settings"
  ],
  "entry_point": "plugin:create_plugin",
  "permissions": [
    "memory.read",
    "memory.write",
    "memory.semantic",
    "memory.markdown",
    "filesystem.read",
    "filesystem.write"
  ],
  "provided_services": [
    "ExecutionHistoryContract",
    "MemoryManagerContract",
    "SemanticMemoryContract",
    "MarkdownMemoryContract"
  ],
  "events_emitted": [
    "memory_cleared",
    "preferences_updated"
  ],
  "tags": ["builtin", "core"]
}
