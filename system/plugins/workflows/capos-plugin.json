{
  "id": "capos.core.workflows",
  "name": "Workflows",
  "version": "1.0.0",
  "dependencies": [
    "capos.core.settings",
    "capos.core.capabilities",
    "capos.core.agent"
  ],
  "entry_point": "plugin:create_plugin",
  "permissions": [
    "workflows.*",
    "tools.execute",
    "agents.execute",
    "filesystem.read",
    "filesystem.write"
  ],
  "provided_services": [
    "WorkflowRegistryContract",
    "WorkflowExecutorContract"
  ],
  "events_emitted": [
    "workflow_step"
  ],
  "tags": ["builtin"]
}
