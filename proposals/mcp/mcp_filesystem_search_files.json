{
  "id": "mcp_filesystem_search_files",
  "name": "filesystem: search_files",
  "domain": "integraciones",
  "type": "integration",
  "description": "Recursively search for files and directories matching a pattern. The patterns should be glob-style patterns that match paths relative to the working directory. Use pattern like '*.ext' to match files in current directory, and '**/*.ext' to match files in all subdirectories. Returns full paths to all matching items. Great for finding files when you don't know their exact location. Only searches within allowed directories.",
  "inputs": {
    "path": {
      "type": "string",
      "required": true
    },
    "pattern": {
      "type": "string",
      "required": true
    },
    "excludePatterns": {
      "type": "array",
      "required": false
    }
  },
  "outputs": {
    "content": {
      "type": "array",
      "description": "MCP response content blocks."
    }
  },
  "requirements": {
    "tools": [
      "mcp_filesystem_search_files"
    ],
    "capabilities": [],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "call_mcp",
        "action": "mcp_filesystem_search_files",
        "params": {
          "path": "{{inputs.path}}",
          "pattern": "{{inputs.pattern}}",
          "excludePatterns": "{{inputs.excludePatterns}}"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": [
      "mcp filesystem search files"
    ]
  },
  "lifecycle": {
    "version": "1.0.0",
    "status": "experimental"
  }
}