{
  "id": "mcp_filesystem_read_media_file",
  "name": "filesystem: read_media_file",
  "domain": "integraciones",
  "type": "integration",
  "description": "Read an image or audio file. Returns the base64 encoded data and MIME type. Only works within allowed directories.",
  "inputs": {
    "path": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "content": {
      "type": "array",
      "description": "MCP response content blocks."
    }
  },
  "requirements": {
    "tools": [
      "mcp_filesystem_read_media_file"
    ],
    "capabilities": [],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "call_mcp",
        "action": "mcp_filesystem_read_media_file",
        "params": {
          "path": "{{inputs.path}}"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": [
      "mcp filesystem read media file"
    ]
  },
  "lifecycle": {
    "version": "1.0.0",
    "status": "experimental"
  }
}