{
  "id": "mcp_filesystem_get_file_info",
  "name": "filesystem: get_file_info",
  "domain": "integraciones",
  "type": "integration",
  "description": "Retrieve detailed metadata about a file or directory. Returns comprehensive information including size, creation time, last modified time, permissions, and type. This tool is perfect for understanding file characteristics without reading the actual content. Only works within allowed directories.",
  "inputs": {
    "path": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "content": {
      "type": "array",
      "description": "MCP response content blocks."
    }
  },
  "requirements": {
    "tools": [
      "mcp_filesystem_get_file_info"
    ],
    "capabilities": [],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "call_mcp",
        "action": "mcp_filesystem_get_file_info",
        "params": {
          "path": "{{inputs.path}}"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": [
      "mcp filesystem get file info"
    ]
  },
  "lifecycle": {
    "version": "1.0.0",
    "status": "experimental"
  }
}