{
  "id": "mcp_filesystem_read_file",
  "name": "filesystem: read_file",
  "domain": "integraciones",
  "type": "integration",
  "description": "Read the complete contents of a file as text. DEPRECATED: Use read_text_file instead.",
  "inputs": {
    "path": {
      "type": "string",
      "required": true
    },
    "tail": {
      "type": "number",
      "required": false,
      "description": "If provided, returns only the last N lines of the file"
    },
    "head": {
      "type": "number",
      "required": false,
      "description": "If provided, returns only the first N lines of the file"
    }
  },
  "outputs": {
    "content": {
      "type": "array",
      "description": "MCP response content blocks."
    }
  },
  "requirements": {
    "tools": [
      "mcp_filesystem_read_file"
    ],
    "capabilities": [],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "call_mcp",
        "action": "mcp_filesystem_read_file",
        "params": {
          "path": "{{inputs.path}}",
          "tail": "{{inputs.tail}}",
          "head": "{{inputs.head}}"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": [
      "mcp filesystem read file"
    ]
  },
  "lifecycle": {
    "version": "1.0.0",
    "status": "experimental"
  }
}