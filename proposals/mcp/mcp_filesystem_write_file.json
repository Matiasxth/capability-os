{
  "id": "mcp_filesystem_write_file",
  "name": "filesystem: write_file",
  "domain": "integraciones",
  "type": "integration",
  "description": "Create a new file or completely overwrite an existing file with new content. Use with caution as it will overwrite existing files without warning. Handles text content with proper encoding. Only works within allowed directories.",
  "inputs": {
    "path": {
      "type": "string",
      "required": true
    },
    "content": {
      "type": "string",
      "required": true
    }
  },
  "outputs": {
    "content": {
      "type": "array",
      "description": "MCP response content blocks."
    }
  },
  "requirements": {
    "tools": [
      "mcp_filesystem_write_file"
    ],
    "capabilities": [],
    "integrations": []
  },
  "strategy": {
    "mode": "sequential",
    "steps": [
      {
        "step_id": "call_mcp",
        "action": "mcp_filesystem_write_file",
        "params": {
          "path": "{{inputs.path}}",
          "content": "{{inputs.content}}"
        }
      }
    ]
  },
  "exposure": {
    "visible_to_user": true,
    "trigger_phrases": [
      "mcp filesystem write file"
    ]
  },
  "lifecycle": {
    "version": "1.0.0",
    "status": "experimental"
  }
}